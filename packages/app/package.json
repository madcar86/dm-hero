{
  "name": "@dm-hero/app",
  "version": "1.0.0",
  "description": "A personal D&D campaign management tool for Dungeon Masters with fuzzy search, entity management, and session tracking",
  "author": "Florian Heuberger",
  "license": "MIT",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Flo0806/dm-hero.git"
  },
  "bugs": {
    "url": "https://github.com/Flo0806/dm-hero/issues"
  },
  "homepage": "https://github.com/Flo0806/dm-hero#readme",
  "keywords": [
    "dnd",
    "dungeons-and-dragons",
    "campaign-management",
    "dungeon-master",
    "dm-tools",
    "rpg",
    "ttrpg",
    "nuxt",
    "vue",
    "vuetify",
    "sqlite",
    "fuzzy-search",
    "entity-management"
  ],
  "main": "electron/main.js",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:electron": "concurrently \"nuxt dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && pnpm rebuild better-sqlite3",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:reset": "node scripts/test-data/reset-and-seed.js",
    "electron:rebuild": "node scripts/electron-rebuild.js",
    "electron:rebuild:linux": "cd $(find node_modules/.pnpm -type d -name 'better-sqlite3' -path '*/node_modules/better-sqlite3' | head -1) && HOME=~/.electron-gyp npx node-gyp rebuild --target=39.2.3 --arch=x64 --dist-url=https://electronjs.org/headers",
    "electron:start": "cross-env NODE_ENV=production electron .",
    "electron:build": "nuxt build && pnpm electron:rebuild && electron-builder --linux",
    "electron:build:win": "nuxt build && pnpm electron:rebuild && electron-builder --win",
    "mode:web": "pnpm rebuild better-sqlite3 && echo '✅ Switched to Web Mode (pnpm dev)'",
    "mode:electron": "pnpm electron:rebuild:linux && echo '✅ Switched to Electron Mode (pnpm electron:start)'"
  },
  "build": {
    "appId": "com.dm-hero.app",
    "productName": "DM Hero",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/icons"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".output",
        "to": ".output",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/better-sqlite3",
        "to": ".output/server/node_modules/better-sqlite3",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/bindings",
        "to": ".output/server/node_modules/bindings",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/file-uri-to-path",
        "to": ".output/server/node_modules/file-uri-to-path",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "npmRebuild": true,
    "publish": {
      "provider": "github",
      "owner": "Flo0806",
      "repo": "dm-hero"
    }
  },
  "dependencies": {
    "@3d-dice/dice-box": "^1.1.4",
    "@iconify/vue": "^5.0.0",
    "@mdi/font": "^7.4.47",
    "@nuxt/test-utils": "3.20.1",
    "@nuxtjs/i18n": "^10.2.0",
    "@pinia/nuxt": "^0.11.3",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.4.6",
    "bindings": "^1.5.0",
    "electron-updater": "^6.6.2",
    "fastest-levenshtein": "^1.0.16",
    "file-uri-to-path": "^1.0.0",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "marked": "^17.0.0",
    "md-editor-v3": "^6.1.1",
    "nuxt": "^4.2.1",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3",
    "vite-plugin-vuetify": "^2.1.2",
    "vue": "^3.5.24",
    "vue-pdf-embed": "^2.1.3",
    "vue-router": "^4.6.3",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.10.9"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@nuxt/eslint": "1.10.0",
    "@oxc-minify/binding-linux-x64-gnu": "^0.97.0",
    "@oxc-parser/binding-linux-x64-gnu": "^0.97.0",
    "@oxc-resolver/binding-linux-x64-gnu": "^11.13.2",
    "@oxc-transform/binding-linux-x64-gnu": "^0.97.0",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.0.3",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.16",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.5.1",
    "happy-dom": "^20.0.10",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.3"
  }
}
